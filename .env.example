# ArangoDB — create a database user dedicated to this app
ARANGO_URL=http://localhost:8529
ARANGO_USER=root
ARANGO_PASS=your_arangodb_password_here
ARANGO_DB=ai_chat_rag

# Ollama servers
# Local server (this machine)
OLLAMA_LOCAL_URL=http://127.0.0.1:11434
# Remote server (optional second GPU machine)
OLLAMA_REMOTE_URL=http://192.168.1.x:11434

# Embedding model — must be pulled first: ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text

# Vision model on remote server used for image file analysis
VISION_MODEL=gemma4:latest
